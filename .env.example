# Tavily API Key for web search
TAVILY_API_KEY=your-tavily-api-key-here

# Ollama Model Configuration (Local Models - NO RATE LIMITS)
# First, install Ollama from https://ollama.ai
# Then download models: ollama pull mistral, ollama pull neural-chat, ollama pull orca-mini
PRIMARY_MODEL=mistral
SECONDARY_MODEL=neural-chat
FALLBACK_MODEL=orca-mini

# Rate limit settings
MAX_RETRIES=3
RETRY_DELAY=2

# Deep research tuning
MAX_SEARCH_RESULTS=10
SUMMARY_LENGTH=4000
